{
  "productName": "FaziPOS",
  "version": "1.2.3",
  "identifier": "com.fazicore.pos",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Fazi POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false,
        "visible": true,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**", "$HOME/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBNTJDRDY0NTZCQjM1NTQKUldSVU5idFdaTTFTNnZRcG9KMkpuL2RCbnQ2eDdOR1J5Q0FKa0tZYW5MbW14YUJWenpJeFFLMmQK",
      "endpoints": [
        "https://github.com/brayohmurithidev/fazicore-pos/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2025 Fazilabs",
    "category": "Business",
    "shortDescription": "Point of Sale system by Fazilabs",
    "longDescription": "FaziPOS is a modern, fast point-of-sale system for retail businesses.",
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "./webview2-runtime/"
      }
    }
  }
}
