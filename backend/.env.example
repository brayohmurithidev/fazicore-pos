# Docker image — set by CI/CD; update this after each deploy if pinning manually
API_IMAGE=ghcr.io/your-github-org/fazicore-pos/api:latest

# App
APP_ENV=production
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_USER=fazipos
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=fazipos

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ACCESS_KEY=replace-with-strong-key
MINIO_SECRET_KEY=replace-with-strong-secret
MINIO_BUCKET_NAME=fazipos
MINIO_SECURE=false
# Browser-reachable hostname — Nginx proxies /fazipos/* to MinIO internally
MINIO_PUBLIC_ENDPOINT=fazistore-api.fazilabs.com

# CORS — exact origins of both Vercel apps (no trailing slash)
CORS_ORIGINS=["https://fazistore.fazilabs.com","https://admin.fazistore.fazilabs.com"]

# Business defaults
BUSINESS_NAME=Fazi POS
CURRENCY=KES
TAX_RATE=0.16
