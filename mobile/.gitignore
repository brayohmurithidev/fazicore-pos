# Flutter/Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
# Note: pubspec.lock IS committed — this is an application, so we want
# reproducible dependency resolution across machines and CI.

# android/ IS committed — it carries permanent native config (camera + Bluetooth
# permissions, etc.). Build artifacts inside it are excluded by android/.gitignore.
# Other platform folders stay generated-locally (this is an Android-only app).
/ios/
/linux/
/macos/
/windows/
/web/

# IDE
.idea/
*.iml
.vscode/

# Misc
.DS_Store
