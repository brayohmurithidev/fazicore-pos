# Docker image — set by CI/CD; update this after each deploy if pinning manually
API_IMAGE=ghcr.io/your-github-org/fazicore-pos/api:latest

# App
APP_ENV=production
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_USER=fazipos
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=fazipos

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ACCESS_KEY=replace-with-strong-key
MINIO_SECRET_KEY=replace-with-strong-secret
MINIO_BUCKET_NAME=fazipos
MINIO_SECURE=false
# Browser-reachable hostname — Nginx proxies /fazipos/* to MinIO internally
MINIO_PUBLIC_ENDPOINT=fazistore-api.fazilabs.com

# CORS — exact origins allowed (no trailing slash)
# tauri://localhost      = macOS/Linux Tauri app
# https://tauri.localhost = Windows Tauri app (WebView2)
CORS_ORIGINS=["https://fazistore.fazilabs.com","https://admin.fazistore.fazilabs.com","tauri://localhost","https://tauri.localhost"]

# Business defaults
BUSINESS_NAME=Fazi POS
CURRENCY=KES
TAX_RATE=0.16

# Platform M-Pesa — Fazi's own Daraja shortcode for collecting subscription payments.
# Leave unset to disable self-serve upgrade (users see "Contact sales" instead).
MPESA_PLATFORM_SHORTCODE=
MPESA_PLATFORM_CONSUMER_KEY=
MPESA_PLATFORM_CONSUMER_SECRET=
MPESA_PLATFORM_PASSKEY=
MPESA_PLATFORM_ENV=production
# Public API URL Safaricom posts callbacks to (no trailing slash)
MPESA_CALLBACK_BASE_URL=https://fazistore-api.fazilabs.com
# Shared secret appended as ?ck= on platform-initiated STK callbacks (subscription
# upgrade / admin payment prompts) — those don't have a tenant MpesaCredentials row
# to source a callback key from. Required for those flows to work at all once a
# callback key is enforced (see app/api/v1/hooks.py). Generate with:
#   openssl rand -base64 24
MPESA_PLATFORM_CALLBACK_KEY=

# ── Central Billing (Fazilabs Invoicing) ─────────────────────────────────────
# Product ID is the FaziCore POS product ID from the billing system.
BILLING_ONBOARD_URL=https://billing.fazilabs.com/api/v1/webhooks/{pos_product_id}/onboard
BILLING_WEBHOOK_SECRET=

# ── Paystack ──────────────────────────────────────────────────────────────────
# Webhook secret from Paystack Dashboard → Settings → Webhooks.
# Paystack signs each event with X-Paystack-Signature (sha512 HMAC).
# Register webhook URL: https://fazistore-api.fazilabs.com/api/v1/hooks/gateway
# Leave blank to skip signature verification (not recommended in production).
PAYSTACK_WEBHOOK_SECRET=
