.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
# Note: pubspec.lock IS committed — this is an application, so we want
# reproducible dependency resolution across machines and CI.

# android/ and ios/ ARE committed — they carry permanent native config (permissions,
# icons, splash screens, etc.). Build artifacts inside are excluded by their own .gitignores.
# Other platform folders stay generated-locally.
/linux/
/macos/
/windows/
/web/

# IDE
.idea/
*.iml
.vscode/

# Misc
.DS_Store
